# Cobalt Environment Variables Template
# ======================================
# Copy this file to .env.production or .env.development
# and fill in the actual values for your deployment

# API Configuration
# The default API URL endpoint for downloading media
# Examples:
#   https://api.cobalt.tools (official)
#   https://your-custom-instance.com (custom instance)
WEB_DEFAULT_API=

# Host Configuration
# Your domain/host where Cobalt is deployed
WEB_HOST=

# Plausible Analytics Configuration
# Set to true to enable analytics, false to disable
WEB_PLAUSIBLE_ENABLED=false
# Your Plausible analytics domain (leave empty if disabled)
WEB_PLAUSIBLE_HOST=

# Feature Flags
# Enable WebCodecs for better video encoding support
WEB_ENABLE_WEBCODECS=true

# Deprecated YouTube HLS support (not recommended for new deployments)
WEB_ENABLE_DEPRECATED_YOUTUBE_HLS=false

# Build Configuration
# Enable source maps for easier debugging (security risk in production)
WEB_SOURCEMAP=false

# Cache Control
# Set HTTP cache max-age for static assets (in seconds)
# 31536000 = 1 year (recommended for production)
WEB_CACHE_MAX_AGE=31536000

# Security Headers
# Enable HTTP Strict-Transport-Security header
WEB_ENABLE_HSTS=true
# HSTS max-age in seconds (31536000 = 1 year)
WEB_HSTS_MAX_AGE=31536000
